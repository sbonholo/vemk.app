rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Users collection
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'nickname', 'gender', 'seeking', 'photoUrl',
          'location', 'geohash', 'locationUpdatedAt',
          'lastActive', 'currentEventId', 'fcmToken',
          'matchCount'
        ]);
      allow delete: if isAdmin();
    }

    // Matches
    match /matches/{matchId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.userIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.userIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.userIds;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.userIds;
      }
    }

    // Likes - the actor writes their own like
    match /likes/{likeId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.fromId || request.auth.uid == resource.data.toId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.fromId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.fromId;
    }

    // Blocks - blocker only
    match /blocks/{blockId} {
      allow get, list: if isSignedIn() && request.auth.uid == resource.data.blockerId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.blockerId;
      allow delete: if isSignedIn() && request.auth.uid == resource.data.blockerId;
    }

    // Events - read-only for authed users
    match /events/{eventId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    // Reports - any signed-in user can create; admin reads
    match /reports/{reportId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.reporterId;
      allow get, list, delete: if isAdmin();
    }

    // Analytics events
    match /analytics_events/{eventId}/events/{eventDocId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
