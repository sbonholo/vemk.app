{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase-applet-config.json",
      ".firebaserc",
      ".env*",
      "**/.*",
      "**/node_modules/**",
      "package*.json",
      "test-headers.txt",
      "firestore.rules",
      "README*"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
